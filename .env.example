# =============================================================================
# DeepRadar Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ---- Required ---------------------------------------------------------------

# Anthropic API key for Claude LLM (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# ---- LLM endpoint (optional) ------------------------------------------------

# Custom API base URL for relay/proxy services (leave empty to use official API)
ANTHROPIC_BASE_URL=https://your-relay.example.com

# ---- Publishing (optional) --------------------------------------------------

# GitHub repo to push daily reports to (format: owner/repo)
REPORTS_REPO=

# GitHub personal access token with repo write permission
# Can also use GITHUB_TOKEN (e.g. in GitHub Actions)
REPORTS_REPO_TOKEN=

# ---- Notifications (optional) -----------------------------------------------

# Webhook URL for success/failure notifications (Slack, Discord, etc.)
DEEPRADAR_WEBHOOK_URL=

# ---- Config path override (optional) ----------------------------------------

# Absolute path to the config directory (default: ./config)
# DEEPRADAR_CONFIG_DIR=/path/to/custom/config
